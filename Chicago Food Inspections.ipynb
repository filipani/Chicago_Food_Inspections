print(df.groupby('Risk')['Results'].value_counts())

#PUNTO 4

# Convert Inspection Date to datetime
df['Inspection Date'] = pd.to_datetime(df['Inspection Date'])

# Group by date and count results
daily_results = df.groupby('Inspection Date')['Results'].value_counts().unstack().fillna(0)
daily_results['Failure Rate'] = daily_results['Fail'] / daily_results.sum(axis=1)

print(daily_results.head())

